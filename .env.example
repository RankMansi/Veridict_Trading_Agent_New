# ── Network (hackathon: Ethereum Sepolia only) ─────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
CHAIN_ID=11155111

# ── Shared hackathon contracts — DO NOT deploy your own for judging ─────────
# See SHARED_CONTRACTS.md or https://github.com/Stephen-Kimoi/ai-trading-agent-template/blob/main/SHARED_CONTRACTS.md
AGENT_REGISTRY_ADDRESS=0x97b07dDc405B0c28B17559aFFE63BdB3632d0ca3
HACKATHON_VAULT_ADDRESS=0x0E7CD8ef9743FEcf94f9103033a044caBD45fC90
RISK_ROUTER_ADDRESS=0xd6A6952545FF6E6E6681c2d15C59f9EB8F40FdBC
REPUTATION_REGISTRY_ADDRESS=0x423a9904e39537a9997fbaF0f220d79D7d545763
VALIDATION_REGISTRY_ADDRESS=0x92bF63E5C7Ac6980f237a7164Ab413BE226187F1

# ValidationRegistry: default ON. Operator (PRIVATE_KEY) posts EIP-712 attestations — registered operators are whitelisted validators.
# Attestation `notes` include Delegation Gap + tribunal + RiskRouter leg (risk-management proof on-chain).
# POST_VALIDATION_ATTESTATION=false
# Skip HOLD checkpoints (default OFF/unset = attest HOLD too). Set true to save gas (only BUY/SELL attested).
# POST_VALIDATION_SKIP_HOLD=true
# Optional: max chars for attestation notes (default 900, cap 2048).
# VALIDATION_ATTESTATION_NOTES_MAX=900

# RiskRouter: operator (PRIVATE_KEY) pays submit gas; agent wallet only signs EIP-712. Use agent if hot wallet must pay.
# RISK_ROUTER_GAS_PAYER=operator
# Call simulateIntent before submit to skip gas on risk rejections (default on).
# HACKATHON_PREFLIGHT_SIMULATE=true
# If posting: score 0–100 (default 100). Use auto for confidence×100.
# AGENT_VALIDATION_SCORE=100

# Sepolia gas (optional): eth_estimateGas + EIP-1559 caps — mirrors Python VERIDICT hackathon helpers
# HACKATHON_ESTIMATE_GAS=false
# HACKATHON_LEGACY_GAS_PRICE=true
# HACKATHON_GAS_LIMIT_ROUTER=450000
# HACKATHON_GAS_LIMIT_VALIDATION=2500000
# HACKATHON_GAS_LIMIT_REP=200000
# HACKATHON_GAS_LIMIT_CLAIM=300000

# ── Wallets ────────────────────────────────────────────────────────────────
# Operator: pays gas, owns ERC-721 agent identity
PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY
# Optional: hot wallet for EIP-712 trade intents (omit to use PRIVATE_KEY)
# AGENT_WALLET_PRIVATE_KEY=

# After `npm run register`
AGENT_ID=

# ── Optional: on-chain display metadata (register script) ──────────────────
# AGENT_NAME=VERIDICT
# AGENT_DESCRIPTION=Policy-bound agent with verifiable provenance

# ── Kraken CLI (https://github.com/kraken-oss/kraken-cli) ───────────────────
# Default: paper trading (`kraken paper …`). Set KRAKEN_LIVE=true only for real orders.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
# KRAKEN_LIVE=true
# Optional: full path on Windows, e.g. C:\Tools\kraken.exe
# KRAKEN_CLI_PATH=
# Public REST for tickers only; paper fills simulated without CLI
# KRAKEN_USE_REST=true

# Trading pair (Kraken CLI standard)
# TRADING_PAIR=BTCUSD
# Synthetic paper equity on dashboard (replay BUY/SELL from checkpoints)
# PAPER_START_USD=10000
# Momentum strategy: min |Δprice|% over window to trade (default 0.06; lower = more trades)
# MomentumStrategy: |Δprice| % over window vs BUY/SELL; max spread % for BUY only
# MOMENTUM_THRESHOLD_PCT=0.5
# MOMENTUM_MAX_SPREAD_PCT=0.1

# ── Optional: only if your RiskRouter exposes setRiskParams (local deploy), not shared hackathon router
# RISK_ROUTER_SET_PARAMS=true

# Optional
# ETHERSCAN_API_KEY=

# ── VERIDICT mechanical policy (template subset) ────────────────────────────
# POLICY_ALLOWED_PAIRS=BTCUSD,ETHUSD
# POLICY_MAX_TRADE_USD=500
